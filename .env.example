# Configurazione Supabase
# Copia questo file in .env e inserisci le tue credenziali reali

# URL del progetto Supabase
REACT_APP_SUPABASE_URL=your_supabase_project_url

# Chiave pubblica (anon key) di Supabase
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key

# Esempio:
# REACT_APP_SUPABASE_URL=https://xyzcompany.supabase.co
# REACT_APP_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Nota: Il file .env è ignorato da Git per sicurezza